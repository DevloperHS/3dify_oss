# Postgres (docker compose up -d)
DATABASE_URL=postgres://threedify:threedify@localhost:5432/threedify
TEST_DATABASE_URL=postgres://threedify:threedify@localhost:5432/threedify_test

# Redis (docker compose up -d)
REDIS_URL=redis://localhost:6379

# Better Auth — generate a secret with: npx @better-auth/cli secret
BETTER_AUTH_SECRET=replace-me
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me

# Cloudinary (Source Image storage) — dashboard: https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=replace-me
CLOUDINARY_API_KEY=replace-me
CLOUDINARY_API_SECRET=replace-me

# Asset (GLB) storage — any S3-compatible store. These defaults point at the
# MinIO container from docker-compose (no cloud account needed). For
# production, point the same vars at Backblaze B2 or Cloudflare R2.
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=threedify-assets
S3_REGION=auto

# Reconstruction — three engines:
#   modal   TripoSR on Modal (T4, vertex-colored GLB). Deploy:
#           modal deploy modal/triposr_app.py → MODAL_TRIPOSR_URL
#   trellis TRELLIS on Modal (L4, UV-textured GLB — higher quality). Deploy:
#           modal deploy modal/trellis_app.py → MODAL_TRELLIS_URL
#   stub    placeholder cube, no Modal account needed
# MODAL_KEY and MODAL_SECRET come from a proxy auth token (Modal dashboard →
# Settings → Proxy Auth Tokens) and are shared by both Modal engines.
RECONSTRUCTION_ENGINE=modal
MODAL_TRIPOSR_URL=replace-me
# MODAL_TRELLIS_URL=replace-me
MODAL_KEY=replace-me
MODAL_SECRET=replace-me
# Optional: reconstruction HTTP timeout in ms (default 240000 — generous, to
# absorb a Modal cold start).
# RECONSTRUCTION_TIMEOUT_MS=240000

# Moderation gate (ticket 06) — requires the Amazon Rekognition AI Moderation
# add-on to be enabled on the Cloudinary account (dashboard → Add-ons, free
# tier available) AND a publicly reachable webhook URL (production deploy, or
# a tunnel during local dev). Off by default: jobs skip the moderating stage.
MODERATION_ENABLED=false
# MODERATION_WEBHOOK_URL=https://your-domain/api/webhooks/cloudinary-moderation
